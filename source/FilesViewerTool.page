<script>
// the Tools shell caps page width and height. drop the width cap on our
// ancestors, then size the panel to the space left below its top edge so only
// the panes scroll and the page stays put. recomputed on resize.
(function () {
    'use strict';

    function unlockAncestors() {
        var wrap = document.querySelector('.fv-wrapper');
        if (!wrap) return;
        var vw = window.innerWidth || document.documentElement.clientWidth;
        var el = wrap.parentElement;
        while (el && el !== document.documentElement) {
            var mw = parseFloat(window.getComputedStyle(el).maxWidth);
            if (!isNaN(mw) && mw > 0 && mw < vw) el.style.setProperty('max-width', 'none', 'important');
            el = el.parentElement;
        }
    }

    function fitHeight() {
        var panel = document.querySelector('.fv-wrapper > .fv-panel');
        if (!panel) return;
        if (window.innerWidth <= 820) { panel.style.height = ''; return; }   // narrow: let it flow

        var vh = document.documentElement.clientHeight || window.innerHeight;
        var rect = panel.getBoundingClientRect();
        var absTop = rect.top + window.pageYOffset;   // distance from doc top, immune to current scroll
        var h = vh - absTop - 28;
        if (h < 360) h = 360;
        panel.style.height = h + 'px';

        // if a footer below still pushes the page past the viewport, trim by the overflow
        var contentH = Math.max(document.documentElement.scrollHeight, document.body ? document.body.scrollHeight : 0);
        var over = contentH - vh;
        if (over > 1) {
            h -= over + 2;
            panel.style.height = (h < 360 ? 360 : h) + 'px';
        }
    }

    function apply() { unlockAncestors(); fitHeight(); }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', apply);
    else apply();
    window.addEventListener('load', apply);
    window.addEventListener('resize', apply);
    // unraid keeps painting after load, so re-measure a few times to settle
    setTimeout(apply, 100);
    setTimeout(apply, 400);
    setTimeout(apply, 800);
})();
</script>
