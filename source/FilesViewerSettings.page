$toggle = function($name, $val, $default = '1', $onLabel = 'Enabled', $offLabel = 'Disabled') {
    $isOn = ((string)($val ?? $default)) === '1';
    return '<input type="hidden" name="' . $name . '" value="' . ($isOn ? '1' : '0') . '">'
        . '<label class="fv-toggle"><input type="checkbox" data-fv-toggle="' . $name . '"' . ($isOn ? ' checked' : '') . '>'
        . '<span class="fv-toggle-track"></span></label>'
        . '<span class="fv-toggle-txt ' . ($isOn ? 'on' : 'off') . '"'
        . ' data-on="'  . htmlspecialchars($onLabel,  ENT_QUOTES) . '"'
        . ' data-off="' . htmlspecialchars($offLabel, ENT_QUOTES) . '">'
        . ($isOn ? $onLabel : $offLabel) . '</span>';
};
$toggleShow = function($name, $val, $default = '1') use ($toggle) {
    return $toggle($name, $val, $default, 'Show', 'Hide');
};
?>

