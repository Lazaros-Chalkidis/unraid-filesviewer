<script>
(function () {
    'use strict';

    // collapsible sections
    document.querySelectorAll('.fv-sec-hd').forEach(function (hd) {
        hd.addEventListener('click', function () {
            hd.parentElement.classList.toggle('closed');
        });
    });

    // mirror each toggle's checkbox into its hidden input and swap the label
    document.querySelectorAll('input[data-fv-toggle]').forEach(function (cb) {
        cb.addEventListener('change', function () {
            var name   = cb.getAttribute('data-fv-toggle');
            var hidden = document.querySelector('input[type="hidden"][name="' + name + '"]');
            if (hidden) hidden.value = cb.checked ? '1' : '0';
            var field = cb.closest('.fv-r-field');
            var txt   = field ? field.querySelector('.fv-toggle-txt') : null;
            if (txt) {
                txt.textContent = cb.checked ? (txt.getAttribute('data-on') || '') : (txt.getAttribute('data-off') || '');
                txt.classList.toggle('on',  cb.checked);
                txt.classList.toggle('off', !cb.checked);
            }
        });
    });

    // let the normal POST fire, then show the button as saving
    var form     = document.querySelector('form[name="filesviewer_settings"]');
    var applyBtn = document.getElementById('fvApplyBtn');
    if (form && applyBtn) {
        form.addEventListener('submit', function () {
            setTimeout(function () {
                applyBtn.disabled  = true;
                applyBtn.innerHTML = '<i class="fa fa-spinner fa-spin" aria-hidden="true"></i> Saving\u2026';
            }, 0);
        });
    }

    // reset to defaults: restore the fields, then ask the user to Apply
    var FV_DEFAULTS = {
        FV_SHOW_HIDDEN:   '0',
        FV_FOLDERS_FIRST: '1',
        FV_REMEMBER:      '1',
        FV_SORT:          'name',
        FV_SORT_DIR:      'asc',
        FV_PERMS_FORMAT:  'octal',
        FV_TEXT_CAP_KB:   '2048',
        FV_MD_RENDER:     '1',
        FV_IMG_MAX_MB:    '50',
        FV_ARCHIVE_MAX:   '1000',
        FV_AUTOPLAY:      '0',
        FV_RECYCLE:       '1',
        FV_RECYCLE_DAYS:  '30'
    };

    function resetDefaults() {
        if (!form) return;

        Object.keys(FV_DEFAULTS).forEach(function (k) {
            var el = form.querySelector('[name="' + k + '"]');
            if (el && el.tagName !== 'INPUT') el.value = FV_DEFAULTS[k];   // textarea and selects
            else if (el && el.type !== 'checkbox' && el.type !== 'hidden') el.value = FV_DEFAULTS[k];
        });

        document.querySelectorAll('.fv-toggle input[type="checkbox"]').forEach(function (cb) {
            var name = cb.getAttribute('data-fv-toggle');
            if (!name || !FV_DEFAULTS.hasOwnProperty(name)) return;
            cb.checked = FV_DEFAULTS[name] === '1';
            var hidden = document.querySelector('input[type="hidden"][name="' + name + '"]');
            if (hidden) hidden.value = cb.checked ? '1' : '0';
            var field = cb.closest('.fv-r-field');
            var txt   = field ? field.querySelector('.fv-toggle-txt') : null;
            if (txt) {
                txt.textContent = cb.checked ? (txt.getAttribute('data-on') || '') : (txt.getAttribute('data-off') || '');
                txt.className = 'fv-toggle-txt ' + (cb.checked ? 'on' : 'off');
            }
        });

        fvShowNotice('Settings reset',
            'The settings have been restored to their default values. Click '
            + '<span style="color:#f47d42;font-weight:600;">Apply</span> to save.');
    }

    var resetBtn = document.getElementById('fvResetBtn');
    if (resetBtn) resetBtn.addEventListener('click', resetDefaults);

    // notice modal
    function fvShowNotice(title, bodyHtml) {
        var nModal = document.getElementById('fvNoticeModal');
        var nTitle = document.getElementById('fvNoticeTitle');
        var nBody  = document.getElementById('fvNoticeBody');
        if (!nModal || !nTitle || !nBody) {
            var plain = (bodyHtml || '').replace(/<[^>]+>/g, '');
            alert(title + (plain ? '\n\n' + plain : ''));
            return;
        }
        nTitle.textContent = title || 'Notice';
        nBody.innerHTML    = bodyHtml || '';
        nModal.style.display = 'flex';
    }
    var nModal = document.getElementById('fvNoticeModal');
    var nOk    = document.getElementById('fvNoticeOkBtn');
    if (nOk && nModal) nOk.addEventListener('click', function () { nModal.style.display = 'none'; });
    if (nModal) {
        nModal.addEventListener('click', function (e) { if (e.target === nModal) nModal.style.display = 'none'; });
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && nModal.style.display !== 'none') nModal.style.display = 'none';
        });
    }

    // credits modal
    var modal = document.getElementById('fvCreditsModal');
    var cLink = document.getElementById('fvCreditsLink');
    var okBtn = document.getElementById('fvCreditsOkBtn');
    if (cLink && modal) cLink.addEventListener('click', function (e) { e.preventDefault(); modal.style.display = 'flex'; });
    if (okBtn && modal) okBtn.addEventListener('click', function () { modal.style.display = 'none'; });
    if (modal) {
        modal.addEventListener('click', function (e) { if (e.target === modal) modal.style.display = 'none'; });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') modal.style.display = 'none'; });
    }
})();
</script>
