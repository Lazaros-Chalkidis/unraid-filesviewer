require_once '/usr/local/emhttp/plugins/dynamix/include/Helpers.php';

const FV_PLUGIN   = 'filesviewer';
const FV_CFG_FILE = '/boot/config/plugins/filesviewer/filesviewer.cfg';

// form sanitizers, every posted value gets clamped through one of these
$yn = static fn($v, $d = '0') => ((string)($v ?? $d) === '1') ? '1' : '0';

$one_of = static function($v, array $allowed, string $default): string {
    $v = strtolower((string)$v);
    return in_array($v, $allowed, true) ? $v : $default;
};

// settings apply: rebuild the cfg from the posted fields, then write it back
if (isset($_POST['#apply'])) {

    $new_cfg = @parse_ini_file(FV_CFG_FILE) ?: [];

    $new_cfg['FV_SHOW_HIDDEN']   = $yn($_POST['FV_SHOW_HIDDEN']   ?? '0', '0');
    $new_cfg['FV_FOLDERS_FIRST'] = $yn($_POST['FV_FOLDERS_FIRST'] ?? '1', '1');
    $new_cfg['FV_REMEMBER']      = $yn($_POST['FV_REMEMBER'] ?? '1', '1');
    $new_cfg['FV_SORT']          = $one_of($_POST['FV_SORT']     ?? 'name', ['name','size','modified'], 'name');
    $new_cfg['FV_SORT_DIR']      = $one_of($_POST['FV_SORT_DIR'] ?? 'asc',  ['asc','desc'], 'asc');
    $new_cfg['FV_PERMS_FORMAT']  = $one_of($_POST['FV_PERMS_FORMAT'] ?? 'octal', ['octal','symbolic'], 'octal');
    $new_cfg['FV_TEXT_CAP_KB']   = $one_of($_POST['FV_TEXT_CAP_KB'] ?? '2048', ['256','512','1024','2048','5120','10240'], '2048');
    $new_cfg['FV_MD_RENDER']     = $yn($_POST['FV_MD_RENDER'] ?? '1', '1');
    $new_cfg['FV_IMG_MAX_MB']    = $one_of($_POST['FV_IMG_MAX_MB'] ?? '50', ['10','25','50','100','250'], '50');
    $new_cfg['FV_ARCHIVE_MAX']   = $one_of($_POST['FV_ARCHIVE_MAX'] ?? '1000', ['200','500','1000','2500','5000'], '1000');
    $new_cfg['FV_AUTOPLAY']      = $yn($_POST['FV_AUTOPLAY'] ?? '0', '0');
    $new_cfg['FV_RECYCLE']       = $yn($_POST['FV_RECYCLE'] ?? '1', '1');
    $new_cfg['FV_RECYCLE_DAYS']  = $one_of($_POST['FV_RECYCLE_DAYS'] ?? '30', ['30','60','never'], '30');

    $ini = '';
    foreach ($new_cfg as $k => $v) {
        $v = preg_replace('/[\x00-\x1f\x7f]/', '', (string)$v);  // strip control chars
        $v = str_replace('"', '\\"', $v);                        // escape quotes so the ini cannot be broken out of
        $ini .= "{$k}=\"{$v}\"\n";
    }
    @mkdir(dirname(FV_CFG_FILE), 0755, true);
    file_put_contents(FV_CFG_FILE, $ini);

    $cfg = $new_cfg;
} else {
    $cfg = @parse_ini_file(FV_CFG_FILE) ?: [];
}

$def = [
    'FV_SHOW_HIDDEN'   => '0',
    'FV_FOLDERS_FIRST' => '1',
    'FV_REMEMBER'      => '1',
    'FV_SORT'          => 'name',
    'FV_SORT_DIR'      => 'asc',
    'FV_PERMS_FORMAT'  => 'octal',
    'FV_TEXT_CAP_KB'   => '2048',
    'FV_MD_RENDER'     => '1',
    'FV_IMG_MAX_MB'    => '50',
    'FV_ARCHIVE_MAX'   => '1000',
    'FV_AUTOPLAY'      => '0',
    'FV_RECYCLE'       => '1',
    'FV_RECYCLE_DAYS'  => '30',
];
$cfg += $def;

$dynamix_cfg  = @parse_ini_file('/boot/config/plugins/dynamix/dynamix.cfg', true);
$unraid_theme = $dynamix_cfg['display']['theme'] ?? '';
$fv_theme     = in_array($unraid_theme, ['black','white','azure','gray'], true) ? $unraid_theme : 'black';
$fv_light     = in_array($fv_theme, ['white','azure'], true);
$themeClass   = ' fv-theme-' . $fv_theme;
$lightClass   = $fv_light ? ' fv-light' : '';
$rootClasses  = $themeClass . $lightClass;

// show the running build, falling back to the .plg metadata and then a label
$plugin_version = '';
$_pvFile = '/usr/local/emhttp/plugins/filesviewer/VERSION';
if (is_readable($_pvFile)) {
    $_pvRead = trim((string)@file_get_contents($_pvFile));
    if ($_pvRead !== '') $plugin_version = $_pvRead;
}
if ($plugin_version === '') {
    $plg = @file_get_contents('/boot/config/plugins/filesviewer/filesviewer.plg');
    if ($plg && preg_match('/<!ENTITY\s+version\s+"([^"]+)"/i', $plg, $m)) {
        $plugin_version = $m[1];
    }
}
if ($plugin_version === '') $plugin_version = 'dev';

